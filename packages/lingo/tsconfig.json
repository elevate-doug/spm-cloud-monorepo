{
  "extends": "@tsconfig/recommended/tsconfig.json",
  "include": ["src"],
  "exclude": ["src/__tests__", "**/*.test.ts", "**/*.test.tsx", "**/*.stories.ts", "**/*.stories.tsx"],
  "compilerOptions": {
    "jsx": "react-jsx",
    "typeRoots": [
      "./node_modules/@types"
    ],
    "paths": {
      "react": ["./node_modules/@types/react"]
    }
  }
}
